{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Sunny",
  "scopeName": "source.sunny",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#booleans" },
    { "include": "#function-definition" },
    { "include": "#keywords" },
    { "include": "#logical-keywords" },
    { "include": "#types" },
    { "include": "#function-call" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.sunny",
          "match": "//.*$"
        },
        {
          "name": "comment.block.sunny",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.sunny",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.sunny",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.sunny",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.sunny",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.sunny",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.sunny",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.sunny",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.control.sunny" },
            "2": { "name": "entity.name.function.sunny" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.sunny",
          "match": "\\b(lit|glow|fn|out|output|if|else|otherwise|match|is|in|for|cycle|ray)\\b"
        }
      ]
    },
    "logical-keywords": {
      "patterns": [
        {
          "name": "keyword.operator.logical.word.sunny",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.sunny",
          "match": "\\b(Int|Float|String|Bool|List|Map|Shadow)\\b"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "variable.function.sunny" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.sunny",
          "match": "->"
        },
        {
          "name": "keyword.operator.comparison.sunny",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.sunny",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.assignment.sunny",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.sunny",
          "match": "[+\\-*/%]"
        }
      ]
    }
  }
}
